{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MindType",
  "version": "1.0.0",
  "identifier": "com.mindtype.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "./src-ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MindType",
        "width": 480,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "center": true,
        "transparent": true
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay.html",
        "width": 200,
        "height": 56,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://mindtype.space/api/releases/latest?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "pubkey": ""
    }
  }
}
